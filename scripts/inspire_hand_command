#!/usr/bin/env python3
"""Send one 0..100 Inspire hand command through FollowJointTrajectory."""

from __future__ import annotations

import argparse
from typing import Dict, Iterable, List

from control_msgs.action import FollowJointTrajectory
import rclpy
from rclpy.action import ActionClient
from rclpy.node import Node
from rclpy.utilities import remove_ros_args

from inspire_tutorials.hand_mapping import (
    joint_names_for_side,
    normalize_hand_selection,
    percentages_to_positions,
    preset_percentages,
)
from inspire_tutorials.trajectory import make_follow_joint_trajectory_goal


class InspireHandActionBridge(Node):
    """Small Python bridge for 0..100 Inspire RH56DFX hand commands."""

    def __init__(self, sides: Iterable[str], action_names: Dict[str, str]) -> None:
        super().__init__("inspire_hand_action_bridge")
        self.sides = tuple(sides)
        self.action_clients = {
            side: ActionClient(self, FollowJointTrajectory, action_names[side])
            for side in self.sides
        }
        self.action_names = action_names

    def wait_for_servers(self, timeout_sec: float) -> bool:
        ok = True
        for side, client in self.action_clients.items():
            if not client.wait_for_server(timeout_sec=timeout_sec):
                self.get_logger().error(
                    "%s hand action server is not available: %s"
                    % (side, self.action_names[side])
                )
                ok = False
        return ok

    def send_percentages(
        self,
        values_0_to_100: Iterable[float],
        duration_sec: float,
        wait: bool = True,
    ) -> bool:
        positions = percentages_to_positions(values_0_to_100)
        futures = []
        for side, client in self.action_clients.items():
            goal = make_follow_joint_trajectory_goal(
                joint_names_for_side(side),
                positions,
                duration_sec,
            )
            future = client.send_goal_async(goal)
            futures.append((side, future))

        success = True
        for side, future in futures:
            rclpy.spin_until_future_complete(self, future)
            goal_handle = future.result()
            if goal_handle is None or not goal_handle.accepted:
                self.get_logger().error("%s hand goal was rejected" % side)
                success = False
                continue
            if not wait:
                continue
            result_future = goal_handle.get_result_async()
            rclpy.spin_until_future_complete(self, result_future)
            result = result_future.result().result
            if result.error_code != FollowJointTrajectory.Result.SUCCESSFUL:
                self.get_logger().error(
                    "%s hand goal failed: error_code=%d, error_string=%s"
                    % (side, result.error_code, result.error_string)
                )
                success = False
        return success


def parse_args(argv: List[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Send Inspire hand values. Values are 0=open and 100=closed for "
            "the six joints: thumb_yaw thumb_pitch index middle ring pinky."
        )
    )
    parser.add_argument("--hand", choices=["right", "left", "both"], default="both")
    parser.add_argument(
        "--values",
        type=float,
        nargs="+",
        help="One value for all joints or six joint values in 0..100.",
    )
    parser.add_argument(
        "--preset",
        choices=[
            "open",
            "close",
            "stop_grasp",
            "prepare_grasp",
            "start_grasp",
            "default_grasp",
        ],
        help="Named command vector compatible with the JSK G1 hand examples.",
    )
    parser.add_argument("--duration", type=float, default=0.8)
    parser.add_argument("--timeout", type=float, default=5.0)
    parser.add_argument("--no-wait", action="store_true")
    parser.add_argument(
        "--right-action",
        default="/right_hand_controller/follow_joint_trajectory",
    )
    parser.add_argument(
        "--left-action",
        default="/left_hand_controller/follow_joint_trajectory",
    )
    return parser.parse_args(argv)


def main(args=None) -> None:
    rosless_args = remove_ros_args(args=args)
    parsed = parse_args(rosless_args[1:] if rosless_args else [])
    if parsed.values is None and parsed.preset is None:
        raise SystemExit("provide --values or --preset")
    if parsed.values is not None and parsed.preset is not None:
        raise SystemExit("provide only one of --values or --preset")

    values = parsed.values if parsed.values is not None else preset_percentages(parsed.preset)
    sides = normalize_hand_selection(parsed.hand)
    action_names = {"right": parsed.right_action, "left": parsed.left_action}

    rclpy.init(args=args)
    node = InspireHandActionBridge(sides, action_names)
    try:
        if not node.wait_for_servers(parsed.timeout):
            raise SystemExit(2)
        ok = node.send_percentages(values, parsed.duration, wait=not parsed.no_wait)
        if not ok:
            raise SystemExit(3)
    finally:
        try:
            node.destroy_node()
        except KeyboardInterrupt:
            pass
        if rclpy.ok():
            try:
                rclpy.shutdown()
            except KeyboardInterrupt:
                pass


if __name__ == "__main__":
    main()
